ocr-gateway.knue.ac.kr {
	tls /etc/caddy/certs/fullchain.pem /etc/caddy/certs/privkey.pem

	request_body {
		# Gateway's MAX_FILE_MB plus 1MB headroom: this limit applies to the
		# whole request body, and multipart framing adds overhead, so an
		# exactly-20MB file must not be rejected here before the gateway
		# (the authoritative limit) sees it.
		max_size 21MB
	}

	reverse_proxy gateway:8080
}
